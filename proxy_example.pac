// ---------- IPv6 判断（中国 IP 段） ----------
const NUM_TRACK_BITS = 64;

/** 将 IPv6 地址转为二进制串，用于 CIDR 匹配 */
function ipv6ToBinary(ip) {
    let bin = "";
    for (let i of ip.split(":")) {
        if (i === '') i = '0';
        if (!i.match(/^[\\da-f]{0,4}$/)) return "0".repeat(NUM_TRACK_BITS)
        bin = bin + parseInt(i, 16).toString(2).padStart(16, '0');
    }
    return bin.padEnd(NUM_TRACK_BITS, '0');
}

/** 判断 ipv6 是否落在某条 CIDR 内 */
function ipv6InCidr(ipv6, cidr) {
    if (!cidr) throw "Missing CIDR Address";
    let [cidrAddress, numBinCidrPrefix] = cidr.split('/');
    numBinCidrPrefix = parseInt(numBinCidrPrefix);
    if (numBinCidrPrefix < 0 || numBinCidrPrefix > 128) throw "Invalid CIDR Address";
    let binCidrAddress = ipv6ToBinary(cidrAddress);
    let minBinCidrAddress = binCidrAddress.substr(0, numBinCidrPrefix).padEnd(NUM_TRACK_BITS, '0');
    let maxBinCidrAddress = binCidrAddress.substr(0, numBinCidrPrefix).padEnd(NUM_TRACK_BITS, '1');
    if (ipv6.indexOf(":") === -1) return false;
    let binIpv6 = ipv6ToBinary(ipv6);
    return binIpv6 >= minBinCidrAddress && binIpv6 <= maxBinCidrAddress;
}

/** 判断 ipv6 是否落在中国 IPv6 CIDR 列表中 */
function ipv6InCidrs(ipv6, cidrs) {
    for (const cidr of cidrs) {
        if (ipv6InCidr(ipv6, cidr)) {
            return true;
        }
    }
    return false;
}

/** 判断是否为局域网 IP */
function isLan(host) {
    return belongsToSubnet(host, LAN);
}

/** 将域名数组转为前缀树结构，便于子域名匹配 */
function to_dict(domains) {
    var domain_dict = {};
    for (var i = 0; i < domains.length; i++) {
        if (domains[i].endsWith(".")) {
            domains[i] = domains[i].slice(0, -1)
        }
        var url_list = domains[i].split('.');
        var domain_node = domain_dict;
        for (var j = url_list.length; j > 0; j--) {
            var node_name = url_list[j - 1];
            if (!domain_node.hasOwnProperty(node_name)) {
                if (j === 1) {
                    domain_node[node_name] = true;
                    break;
                } else {
                    domain_node[node_name] = {};
                }
            } else if (domain_node[node_name] === true) {
                break;
            }
            domain_node = domain_node[node_name];
        }
    }
    return domain_dict;
}

directDomains = to_dict(directDomains);
domainsUsingProxy = to_dict(domainsUsingProxy);

// ---------- 按业务分组的域名（OpenAI/Netflix/Google 等），统一走本地代理 127.0.0.1:8888 ----------
var mzk_cdn_server = {};
mzk_cdn_server.openai = {};
mzk_cdn_server.openai.server = proxy;
mzk_cdn_server.openai.domain = ["gravatar.com", "openai.com", "chatgpt.com", "oaistatic.com", "sentry.io", "claude.ai"];
mzk_cdn_server.openai.domain = to_dict(mzk_cdn_server.openai.domain);
mzk_cdn_server.nfvideo = {};
mzk_cdn_server.nfvideo.server = proxy;
mzk_cdn_server.nfvideo.domain = ["netflix.com", "netflix.net", "netflixdnstest1.com", "netflixdnstest10.com", "netflixdnstest2.com", "netflixdnstest3.com", "netflixdnstest4.com", "netflixdnstest5.com", "netflixdnstest6.com", "netflixdnstest7.com", "netflixdnstest8.com", "netflixdnstest9.com", "netflixinvestor.com", "netflixtechblog.com", "nflxext.com", "nflximg.com", "nflximg.net", "nflxsearch.net", "nflxso.net", "nflxvideo.net", "byteoversea.com", "muscdn.com", "musical.ly", "tik-tokapi.com", "tiktok.com", "tiktokcdn.com", "tiktokv.com", "p16-tiktokcdn-com.akamaized.net"];
mzk_cdn_server.nfvideo.domain = to_dict(mzk_cdn_server.nfvideo.domain);
mzk_cdn_server.google = {};
mzk_cdn_server.google.server = proxy;
mzk_cdn_server.google.domain = ["bard.google.com", "gemini.google.com", "copilot.microsoft.com"];
mzk_cdn_server.google.domain = to_dict(mzk_cdn_server.google.domain);

/** 检查 host 是否匹配域名前缀树（含子域名） */
function testDomain(host, domain_dict) {
    var host_list = host.split('.')
    var domain_node = domain_dict
    for (var i = host_list.length; i > 0; i--) {
        var node_name = host_list[i - 1]
        if (domain_node.hasOwnProperty(node_name)) {
            if (domain_node[node_name] === true) {
                return true;
            } else {
                domain_node = domain_node[node_name]
            }
        } else {
            return false;
        }
    }
    return false;
}

/** 若域名属于 OpenAI/Netflix/Google 等分组，返回对应代理配置（本地 127.0.0.1:8888） */
function isMzkCdnDomain(domain) {
    for (var k in mzk_cdn_server) {
        if (testDomain(domain, mzk_cdn_server[k].domain)) {
            return mzk_cdn_server[k].server;
        }
    }
    return false;
}

/** 判断是否为本地测试 TLD（.localhost / .local / .test） */
function isLocalTestDomain(domain) {
    var tld = domain.substring(domain.lastIndexOf('.'));
    if (tld === domain) {
        return false;
    }
    return Object.hasOwnProperty.call(localTlds, tld);
}

/** 测速等特殊域名：也走本地代理，由 Go 转发 */
function isTestSpeedDomain(host) {
    if (typeof its_testdomain[host] !== "undefined") {
        return proxy;
    }
    return false;
}

/** 兼容未提供 dnsResolveEx 的环境 */
if (typeof dnsResolveEx !== 'function') {
    function dnsResolveEx(host) {
        return dnsResolve(host);
    }
}

// ---------- PAC 入口 ----------
// 根据 url/host 返回 "PROXY 127.0.0.1:8888" 或 "DIRECT"
function FindProxyForURL(url, host) {
    // 纯主机名、本地测试域、localhost -> 直连
    if (isPlainHostName(host) || isLocalTestDomain(host) || host === 'localhost') {
        return direct;
    }
    // itestspeed 测速域名 -> 走本地代理
    if (/itestspeed\\.xyz$/ig.test(host)) {
        its = isTestSpeedDomain(host);
        if (its !== false) return its;
    }
    // 按域名判断（未解析成 IP 时）
    if (!ipRegExp.test(host) && !shExpMatch(host, "*:*")) {
        if (testDomain(host, directDomains)) {
            return direct;
        }
        var iscdnserver = isMzkCdnDomain(host);
        if (iscdnserver !== false) return iscdnserver;
        if (testDomain(host, domainsUsingProxy)) {
            return proxy;
        }
        var strIp = dnsResolve(host);
    } else {
        var strIp = host;
    }

    // 按 IP 判断：无中国 IP 表则默认直连
    if (cnips.length < 1) return direct;
    // IPv6 且在中国段 -> 直连
    if (shExpMatch(strIp, "*:*") && ipv6InCidrs(strIp, CN_ipv6_list)) {
        return direct;
    }
    // 解析失败 -> 走代理
    if (!strIp) {
        return proxy;
    }
    // 局域网 -> 直连
    if (isLan(strIp)) {
        return direct;
    }
    // 中国 IP（IPv4 段）-> 直连
    if (isGeoip(strIp)) {
        return direct;
    }
    // 其余 -> 走本地代理
    return proxy;
}